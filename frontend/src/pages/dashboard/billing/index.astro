---
import DashboardLayout from '../../../layouts/Dashboard.astro';
---

<DashboardLayout title="Billing - TerasVPS">
  <div class="space-y-6">
    <div>
      <h1 class="text-3xl font-bold">Billing & Invoices</h1>
      <p class="mt-2 text-muted-foreground">Manage your invoices and payments</p>
    </div>

    <!-- Invoices List -->
    <div id="invoicesList" class="space-y-4">
      <div class="text-center py-8 text-muted-foreground">
        Loading invoices...
      </div>
    </div>

    <!-- Empty State -->
    <div id="emptyState" class="hidden text-center py-12">
      <div class="text-6xl mb-4">💳</div>
      <h3 class="text-xl font-semibold mb-2">No Invoices Yet</h3>
      <p class="text-muted-foreground">
        Your invoices will appear here once you create a VM
      </p>
    </div>
  </div>

  <script>
    // Fetch invoices from API
    async function fetchInvoices() {
      try {
        const token = localStorage.getItem('token');
        const response = await fetch('/api/v1/billing/invoices', {
          headers: {
            'Authorization': `Bearer ${token}`,
          },
        });

        const data = await response.json();

        if (data.success) {
          const invoices = data.data.invoices;
          const invoicesList = document.getElementById('invoicesList');
          const emptyState = document.getElementById('emptyState');

          if (invoices.length === 0) {
            invoicesList.classList.add('hidden');
            emptyState.classList.remove('hidden');
          } else {
            invoicesList.innerHTML = invoices.map(invoice => `
              <div class="p-6 bg-card rounded-lg border border-border">
                <div class="flex items-center justify-between">
                  <div>
                    <h3 class="text-lg font-semibold">${invoice.invoice_number}</h3>
                    <p class="text-sm text-muted-foreground">
                      Due: ${new Date(invoice.due_date).toLocaleDateString()}
                    </p>
                    <div class="mt-2 text-sm">
                      <span class="px-2 py-1 rounded ${
                        invoice.status === 'paid' ? 'bg-green-100 text-green-800' :
                        invoice.status === 'unpaid' ? 'bg-yellow-100 text-yellow-800' :
                        invoice.status === 'overdue' ? 'bg-red-100 text-red-800' :
                        'bg-gray-100 text-gray-800'
                      }">
                        ${invoice.status.toUpperCase()}
                      </span>
                    </div>
                  </div>
                  <div class="text-right">
                    <div class="text-2xl font-bold">Rp ${invoice.amount.toLocaleString()}</div>
                    <a
                      href="/dashboard/billing/invoices/${invoice.id}"
                      class="text-primary hover:underline"
                    >
                      View Details →
                    </a>
                  </div>
                </div>
              </div>
            `).join('');
          }
        }
      } catch (error) {
        console.error('Failed to fetch invoices:', error);
        document.getElementById('invoicesList').innerHTML = `
          <div class="text-center py-8 text-destructive">
            Failed to load invoices. Please try again.
          </div>
        `;
      }
    }

    // Fetch invoices on load
    fetchInvoices();
  </script>
</DashboardLayout>
