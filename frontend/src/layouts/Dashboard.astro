---
import Layout from './Layout.astro';

interface Props {
  title?: string;
}

const { title = "Dashboard - TerasVPS" } = Astro.props;
---

<Layout title={title}>
  <div class="min-h-screen bg-background">
    <!-- Sidebar -->
    <aside class="fixed left-0 top-0 h-full w-64 bg-card border-r border-border">
      <div class="p-6">
        <h1 class="text-2xl font-bold text-primary">TerasVPS</h1>
      </div>

      <nav class="mt-6 px-4 space-y-2">
        <a
          href="/dashboard"
          class="flex items-center px-4 py-3 rounded-lg text-foreground hover:bg-accent hover:text-accent-foreground"
        >
          <span class="mr-3">🏠</span>
          Dashboard
        </a>

        <a
          href="/dashboard/vms"
          class="flex items-center px-4 py-3 rounded-lg text-foreground hover:bg-accent hover:text-accent-foreground"
        >
          <span class="mr-3">🖥️</span>
          My VMs
        </a>

        <a
          href="/dashboard/billing"
          class="flex items-center px-4 py-3 rounded-lg text-foreground hover:bg-accent hover:text-accent-foreground"
        >
          <span class="mr-3">💳</span>
          Billing
        </a>

        <a
          href="/dashboard/settings"
          class="flex items-center px-4 py-3 rounded-lg text-foreground hover:bg-accent hover:text-accent-foreground"
        >
          <span class="mr-3">⚙️</span>
          Settings
        </a>
      </nav>

      <div class="absolute bottom-0 left-0 right-0 p-4 border-t border-border">
        <a
          href="/auth/logout"
          class="flex items-center px-4 py-2 rounded-lg text-destructive hover:bg-destructive/10"
        >
          <span class="mr-3">🚪</span>
          Logout
        </a>
      </div>
    </aside>

    <!-- Main Content -->
    <main class="ml-64 p-8">
      <slot />
    </main>
  </div>
</Layout>
