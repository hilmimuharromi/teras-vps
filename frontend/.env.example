# ===========================================
# TerasVPS Frontend Environment Variables
# ===========================================

# Backend API URL
VITE_API_URL=http://localhost:3000

# Site Configuration
VITE_SITE_NAME=TerasVPS
VITE_SITE_URL=https://terasvps.id
VITE_SITE_DESCRIPTION=VPS Hosting Indonesia dengan Harga Terjangkau

# Stripe (if using Stripe for payment)
# VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here

# Google Analytics (optional)
# VITE_GA_ID=G-XXXXXXXXXX

# Feature Flags
VITE_ENABLE_DASHBOARD=true
VITE_ENABLE_BILLING=true
VITE_ENABLE_SUPPORT=true
